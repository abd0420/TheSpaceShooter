{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Raylib (GCC)",
            "type": "shell",
            "command": "C:/msys64/mingw64/bin/g++.exe",
            "args": [
                "${workspaceFolder}\\*.cpp",

                "-IC:/msys64/mingw64/include",
                "-LC:/msys64/mingw64/lib",

                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-lpthread",
                "-lm",
                "-luser32",
                "-lkernel32",
                "-lshell32",

                "-o",
                "${workspaceFolder}\\main.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
